APP_URL=http://localhost:3000
SESSION_SECRET=replace-with-a-long-random-string
DATABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
AI_API_KEY=
AI_MODEL=claude-sonnet-4-6
# Leave both empty to disable remote AI and use local fallback narratives.
# Never commit a real third-party URL into this template.
AI_BASE_URL_PRIMARY=
AI_BASE_URL_SECONDARY=
ALLTICK_API_KEY=
ALLTICK_STOCK_BASE_URL=https://quote.alltick.co/quote-stock-b-api

# Set true ONLY for the offline teacher-laptop demo where you want the app to
# silently fall back to the in-memory seed store when Postgres is unreachable.
# In production keep this unset/false so DB outages surface as 503s.
ALLOW_MEMORY_FALLBACK=false

# WeChat Pay (optional — leave empty to disable payment features)
# Apply at https://pay.weixin.qq.com/ to get merchant credentials.
WECHAT_MCH_ID=
WECHAT_API_KEY_V3=
WECHAT_APP_ID=
WECHAT_NOTIFY_URL=
WECHAT_PRIVATE_KEY=
WECHAT_CERT_SERIAL_NO=
WECHAT_PLATFORM_PUBLIC_KEY=
WECHAT_PAY_MOCK_MODE=false
WECHAT_PAY_SKIP_NOTIFY_SIGNATURE=false

# Transactional email (Resend) — email verification + password reset.
# Without these, those flows degrade to dev-surfaced links (no email sent).
RESEND_API_KEY=
EMAIL_FROM="Mr.Brown 经济沙盘 <noreply@yourdomain.com>"
# A1 enforcement gray-launch. When "true", unverified trial/free users are
# blocked from the personalized AI assessment. Default off — enable once email
# delivery (Resend) is confirmed working in production.
REQUIRE_EMAIL_VERIFICATION=false
# Shared secret for the Vercel Cron weekly parent-report job (vercel.json).
# Set in Vercel project env; Vercel Cron sends it as "Authorization: Bearer ...".
CRON_SECRET=
