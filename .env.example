APP_URL=http://localhost:3000
SESSION_SECRET=replace-with-a-long-random-string
DATABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
AI_API_KEY=
AI_MODEL=claude-sonnet-4-6
# Leave both empty to disable remote AI and use local fallback narratives.
# Never commit a real third-party URL into this template.
AI_BASE_URL_PRIMARY=
AI_BASE_URL_SECONDARY=
# iTick stock market data (server-side only). Keep the real token in .env.local
# or Vercel Environment Variables; never expose it to the browser.
ITICK_API_TOKEN=
ITICK_REST_BASE_URL=https://api0.itick.org
ITICK_STOCK_WS_URL=wss://api.itick.org/stock
# Legacy fallback provider. Leave empty if you only use iTick + teaching pool.
ALLTICK_API_KEY=
ALLTICK_STOCK_BASE_URL=https://quote.alltick.co/quote-stock-b-api
# Tsanghi (沧海数据) — real EOD/daily bars, primary market data source.
# Host is www.tsanghi.com/api/fin (NOT api.tsanghi.com). Free token = daily only
# (realtime is plan-gated); the market layer falls through to iTick/AllTick/teaching.
TSANGHI_API_TOKEN=
TSANGHI_REST_BASE_URL=https://www.tsanghi.com/api/fin

# Set true ONLY for the offline teacher-laptop demo where you want the app to
# silently fall back to the in-memory seed store when Postgres is unreachable.
# In production keep this unset/false so DB outages surface as 503s.
ALLOW_MEMORY_FALLBACK=false

# Per-request RLS enforcement (docs/rls-enforcement-staging-plan.md). Off by
# default: user-scoped queries run on the owner connection (RLS bypassed) exactly
# as before. Set true in staging/prod to make withUserRls() drop to the
# `authenticated` role so policies are enforced. Roll back by flipping to false.
RLS_ENFORCE=false

# WeChat Pay (optional — official Native/JSAPI dynamic QR with callback).
# A personal/static collection QR cannot auto-open subscriptions; use merchant
# credentials from https://pay.weixin.qq.com/ for real paid subscriptions.
WECHAT_MCH_ID=
WECHAT_API_KEY_V3=
WECHAT_APP_ID=
WECHAT_NOTIFY_URL=
WECHAT_PRIVATE_KEY=
WECHAT_CERT_SERIAL_NO=
WECHAT_PLATFORM_PUBLIC_KEY=
WECHAT_PAY_MOCK_MODE=false
WECHAT_PAY_SKIP_NOTIFY_SIGNATURE=false

# Manual WeChat collection fallback (no merchant callback). Put a public image
# URL for a static WeChat collection QR here. Users submit the transfer note,
# then superadmin verifies the money and opens the subscription in /admin.
WECHAT_MANUAL_QR_URL=
WECHAT_MANUAL_PAYEE_NAME=
WECHAT_MANUAL_INSTRUCTION=

# Transactional email (Resend) — email verification + password reset.
# Without these, those flows degrade to dev-surfaced links (no email sent).
RESEND_API_KEY=
EMAIL_FROM="Mr.Brown 经济沙盘 <noreply@yourdomain.com>"
# A1 enforcement gray-launch. When "true", unverified trial/free users are
# blocked from the personalized AI assessment. Default off — enable once email
# delivery (Resend) is confirmed working in production.
REQUIRE_EMAIL_VERIFICATION=false
# Shared secret for the Vercel Cron weekly parent-report job (vercel.json).
# Set in Vercel project env; Vercel Cron sends it as "Authorization: Bearer ...".
CRON_SECRET=

# Database seed (scripts/seed.ts) production safety.
# In production (NODE_ENV=production) the seed NEVER plants the public-password
# demo accounts or the public invite codes (MRB-STUDENT/PARENT/TEACHER-2026).
# Instead it creates at most ONE admin from the two vars below — set BOTH to
# bootstrap a single strong admin; leave them empty to seed no admin at all
# (then create one out-of-band). Never reuse a documented/public password here.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
# Escape hatch: set SEED_DEMO=true to force the FULL demo data set even when
# NODE_ENV=production (e.g. a private staging box). Leave unset in real prod.
SEED_DEMO=false
