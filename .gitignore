# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
.next-start-*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# local QA artifacts
.qa-screens/
.tools/
.codex-supervisor/
/test-results/
/agency-agents-review/
/tmp-ui-check/
.cloudflared/

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# 会话/内测临时产物（Tailwind v4 自动内容扫描会读未忽略文件——曾因 CI 覆盖率报告的 &#x27; 转义类名打挂 dev 编译）
/.tmp/
